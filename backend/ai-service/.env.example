# Application
PORT=8004
API_PREFIX=/api/v1

# LLM provider selection. Swap to "claude" or "openai" by adding a new
# provider class in src/providers/ and setting this env var — no other
# changes required.
LLM_PROVIDER=ollama

# Ollama configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Future Claude provider (unused while LLM_PROVIDER=ollama)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS
CORS_ORIGIN=http://localhost:3000

# Generation defaults
MAX_TOKENS=512
TEMPERATURE=0.7
