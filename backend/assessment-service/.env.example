# Application
NODE_ENV=development
PORT=8003
API_PREFIX=/api/v1

# Database (Uses port 5435 for assessments)
DB_HOST=localhost
DB_PORT=5435
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=codesphere_assessments

# JWT Configuration (shared with auth-service)
JWT_ACCESS_SECRET=your-access-token-secret-key-here
JWT_REFRESH_SECRET=your-refresh-token-secret-key-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Email Service (NodeMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=CodeSphere <noreply@codesphere.com>

# Service URLs
AUTH_SERVICE_URL=http://localhost:8000
PROBLEM_SERVICE_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# Assessment Settings
DEFAULT_ASSESSMENT_DURATION_MINUTES=120
INVITATION_TOKEN_EXPIRY_DAYS=7
