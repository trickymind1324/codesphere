# Application
NODE_ENV=development
PORT=8002
API_PREFIX=/api/v1

# JWT Configuration (shared with other services)
JWT_ACCESS_SECRET=your-access-token-secret-key-here

# Redis (for queue management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=50

# Execution Configuration
MAX_EXECUTION_TIME_MS=5000
MAX_MEMORY_MB=256
MAX_OUTPUT_SIZE_BYTES=1048576
MAX_CONCURRENT_EXECUTIONS=10

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
ENABLE_DOCKER=true

# Sandbox Configuration
SANDBOX_TEMP_DIR=/tmp/codesphere-sandbox
CLEANUP_TEMP_FILES=true
SANDBOX_NETWORK_ENABLED=false

# Service URLs
PROBLEM_SERVICE_URL=http://localhost:8001

# Assessment session validation (anonymous candidate execution)
ASSESSMENT_SERVICE_URL=http://localhost:8003
