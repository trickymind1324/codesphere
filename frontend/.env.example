# Frontend Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# OAuth URLs (for redirect)
VITE_GOOGLE_OAUTH_URL=http://localhost:8000/api/v1/auth/oauth/google
VITE_GITHUB_OAUTH_URL=http://localhost:8000/api/v1/auth/oauth/github
VITE_LINKEDIN_OAUTH_URL=http://localhost:8000/api/v1/auth/oauth/linkedin

# Stripe Publishable Key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Analytics (Optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://your-sentry-dsn

# Feature Flags
VITE_ENABLE_AI_TUTOR=true
VITE_ENABLE_CODE_PLAYBACK=true
VITE_ENABLE_WHITEBOARD=true

# Environment
VITE_APP_ENV=development
